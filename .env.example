# ---- Convex ----
# Get these by running: npx convex dev
# Convex will create a project and auto-populate your .env.local.
CONVEX_DEPLOYMENT=
CONVEX_URL=
VITE_CONVEX_URL=

# ---- WhatsApp transport (Baileys, embedded) ----
# The agent runs as a *linked* WhatsApp Web device. The QR code prints in
# the dev server terminal on first run; scan it with the WhatsApp app on
# the phone that hosts the agent's number.
#
# WHATSAPP_AGENT_NUMBER: the agent's own WhatsApp number (E.164 format).
#   Used only for logging / banner display. The actual outbound identity
#   is whatever account you scan the QR with.
# WHATSAPP_ALLOWED_NUMBERS: comma-separated E.164 list. Inbound messages
#   from numbers NOT in this list are logged and dropped (never reach the
#   dispatcher). Group chats are always dropped.
# WHATSAPP_SESSION_DIR: where Baileys stores its multi-file auth state.
#   Defaults to ./auth_info_baileys. Add to your backup if you don't want
#   to re-scan QR after deleting the dir.
WHATSAPP_AGENT_NUMBER=+16282809557
WHATSAPP_ALLOWED_NUMBERS=+541123867005
WHATSAPP_SESSION_DIR=./auth_info_baileys

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
# This is the *fallback*; runtime overrides set via the iMessage set_model tool
# (stored in the Convex `settings` table) take precedence.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Proactive email surfacing ----
# Phone number that receives proactive iMessage notices when the Gmail watcher
# decides an inbound email is worth surfacing. Single-user assumption for v1.
# Without this, the webhook still registers but notices are dropped.
BOOP_USER_PHONE=+541123867005
# Set to "false" to skip auto-registering the Composio webhook URL on each
# `npm run dev`. Use when you want to manage the subscription manually.
# COMPOSIO_AUTO_WEBHOOK=

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — paid providers for memory recall) ----
# Tried in order: Voyage → OpenAI → local Transformers.js (Xenova/bge-large-
# en-v1.5, 1024-dim, free, ~440MB one-time download). Leave both blank to
# use the local fallback. All three produce 1024-dim vectors so the Convex
# index stays compatible regardless of which is active.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're using free ngrok (URL changes each restart).
# - Set to your stable public URL (e.g. https://boop.mydomain.com) if you use
#   Cloudflare Tunnel, a Caddy server, or any other tunnel with a fixed URL —
#   `npm run dev` will then skip ngrok.
PUBLIC_URL=http://localhost:3456

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# ---- RevenueCat (custom MCP, read-only) ----
# Each project that uses RevenueCat has its own API key (Alfredo's setup is
# multi-RC-project: Mila / PepBuddy / rosibel-clientes are separate RC
# projects). Per-project env var convention: REVENUECAT_API_KEY_<UPPER_SNAKE_PROJECT_SLUG>
# Add the env var name to the project's registry metadata via the dashboard's
# Projects tab: metadata.revenuecat_api_key_env = "REVENUECAT_API_KEY_MILA",
# metadata.revenuecat_app_id = "<RC app id>".
# Examples (uncomment + fill in the keys you actually have):
# REVENUECAT_API_KEY_MILA=sk_...
# REVENUECAT_API_KEY_PEPBUDDY=sk_...
# REVENUECAT_API_KEY_ROSIBEL_CLIENTES=sk_...

# ---- App Store Connect (ASC) — Spec 4 ----
# Single API key shared across all iOS apps in the team (Mila, PepBuddy,
# rosi-client-app for iOS submissions). Generate at:
#   App Store Connect → Users and Access → Integrations → Keys
# Role: App Manager (sufficient for build management).
# Save the .p8 with mode 600:
#   mkdir -p ~/.appstoreconnect && chmod 700 ~/.appstoreconnect
#   mv ~/Downloads/AuthKey_<KEY_ID>.p8 ~/.appstoreconnect/
#   chmod 600 ~/.appstoreconnect/AuthKey_<KEY_ID>.p8
ASC_API_KEY_ID=
ASC_ISSUER_ID=
ASC_API_KEY_PATH=/Users/Alfredo/.appstoreconnect/AuthKey_REPLACE_ME.p8
